<% content_for(:page_title) { t("administrate.actions.show_resource", name: page.page_title) } %>

<div class="card mb-3">
  <div class="card-header">
    <h3 class="card-title">
      <i class="ti ti-info-circle me-1"></i> <%= display_resource_name(page.resource_name, singular: true) %> Details
    </h3>
    <div class="card-actions">
      <% if accessible_action?(page.resource, :edit) %>
        <%= link_to [:edit, namespace, page.resource], class: "btn btn-sm btn-primary" do %>
          <i class="ti ti-edit me-1"></i> Edit
        <% end %>
      <% end %>
    </div>
  </div>
  <div class="card-body p-0">
    <table class="table table-vcenter card-table">
      <tbody>
        <% page.attributes.each do |title, attributes| %>
          <% if title.present? %>
            <tr>
              <td colspan="2" class="bg-light">
                <strong><%= t "helpers.label.#{page.resource_name}.#{title}", default: title %></strong>
              </td>
            </tr>
          <% end %>
          <% attributes.each do |attribute| %>
            <tr>
              <td class="text-secondary" style="width: 200px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                <%= t(
                  "helpers.label.#{resource_name}.#{attribute.name}",
                  default: page.resource.class.human_attribute_name(attribute.name),
                ) %>
              </td>
              <td><%= render_field attribute, page: page %></td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="d-flex gap-2">
  <%= link_to(
    url_for(action: :index),
    class: "btn btn-outline-secondary"
  ) do %>
    <i class="ti ti-arrow-left me-1"></i> Back to <%= display_resource_name(page.resource_name) %>
  <% end %>

  <% if accessible_action?(page.resource, :destroy) %>
    <%= link_to(
      [namespace, page.resource],
      method: :delete,
      data: { confirm: t("administrate.actions.confirm") },
      class: "btn btn-outline-danger ms-auto"
    ) do %>
      <i class="ti ti-trash me-1"></i> Delete
    <% end %>
  <% end %>
</div>
